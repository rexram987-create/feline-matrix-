    <script>
        let currentLang = 'he';
        function toggleLanguage() {
            currentLang = currentLang === 'he' ? 'en' : 'he';
            document.documentElement.lang = currentLang;
            document.documentElement.dir = currentLang === 'he' ? 'rtl' : 'ltr';
            document.getElementById('langBtn').innerText = currentLang === 'he' ? 'EN' : 'HE';
            document.querySelectorAll('.he-content').forEach(el => el.classList.toggle('hidden', currentLang !== 'he'));
            document.querySelectorAll('.en-content').forEach(el => el.classList.toggle('hidden', currentLang !== 'en'));
        }
        function openImageModal(imgUrl) {
            const modal = document.getElementById('fullScreenImageModal');
            const imgEl = document.getElementById('modalFullImg');
            if(modal && imgEl) { imgEl.src = imgUrl; modal.classList.remove('hidden'); }
        }
        function closeImageModal() {
            const modal = document.getElementById('fullScreenImageModal');
            if(modal) {
                modal.classList.add('hidden');
                setTimeout(() => { document.getElementById('modalFullImg').src = ''; }, 100);
            }
        }
    </script>
